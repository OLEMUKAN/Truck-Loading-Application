@page
@model Truck_Loading_Application.Pages.Trucks.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Truck[0].Type)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Truck[0].AxleLoad)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Truck[0].Brand)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Truck[0].Model)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Truck[0].RegistrationNumber)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Truck[0].EmptyWeight)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Truck[0].MaxLoadWeight)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Truck[0].Size)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Truck[0].Capacity)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Truck[0].Availability)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Truck[0].CurrentLocation)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Truck[0].MaintenanceStatus)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Truck[0].Driver)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Truck[0].IsDeleted)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Truck) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Type)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.AxleLoad)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Brand)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Model)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.RegistrationNumber)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EmptyWeight)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MaxLoadWeight)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Size)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Capacity)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Availability)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CurrentLocation)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MaintenanceStatus)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Driver.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IsDeleted)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.TruckId">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.TruckId">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.TruckId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
