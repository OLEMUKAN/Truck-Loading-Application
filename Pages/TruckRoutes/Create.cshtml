@page
@model Truck_Loading_Application.Pages.TruckRoutes.CreateModel

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>TruckRoute</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="TruckRoute.TruckId" class="control-label"></label>
                <select asp-for="TruckRoute.TruckId" class ="form-control" asp-items="ViewBag.TruckId"></select>
            </div>
            <div class="form-group">
                <label asp-for="TruckRoute.TravelRoute" class="control-label"></label>
                <input asp-for="TruckRoute.TravelRoute" class="form-control" />
                <span asp-validation-for="TruckRoute.TravelRoute" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TruckRoute.PostingTime" class="control-label"></label>
                <input asp-for="TruckRoute.PostingTime" class="form-control" />
                <span asp-validation-for="TruckRoute.PostingTime" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TruckRoute.EstimatedTravelTime" class="control-label"></label>
                <input asp-for="TruckRoute.EstimatedTravelTime" class="form-control" />
                <span asp-validation-for="TruckRoute.EstimatedTravelTime" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TruckRoute.Distance" class="control-label"></label>
                <input asp-for="TruckRoute.Distance" class="form-control" />
                <span asp-validation-for="TruckRoute.Distance" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
