@page
@model Truck_Loading_Application.Pages.Reports.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Report[0].Type)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Report[0].Content)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Report[0].Format)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Report[0].Truck)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Report[0].CreatedAt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Report[0].UpdatedAt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Report[0].CreatedByUser)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Report[0].UpdatedByUser)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Report[0].IsDeleted)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Report[0].DeletedAt)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Report) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Type)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Content)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Format)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Truck.RegistrationNumber)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CreatedAt)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.UpdatedAt)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CreatedByUser.FirstName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.UpdatedByUser.FirstName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IsDeleted)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DeletedAt)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.ReportId">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.ReportId">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.ReportId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
